generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  user_id    String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       String   @default("USER")
  created_at DateTime @default(now())

  refreshtoken RefreshToken?
  wallet       Wallet[]
  orders       Order[]
}

model RefreshToken {
  refreshtoken_id String @id @default(uuid())

  user_id String @unique

  token_hash String @unique

  expires_at DateTime
  created_at DateTime  @default(now())
  revoked_at DateTime?

  user User @relation(fields: [user_id], references: [user_id])
}

model Wallet {
  wallet_id  String   @id @default(uuid())
  user_id    String   @unique
  balance    Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user         User                @relation(fields: [user_id], references: [user_id])
  transactions WalletTransaction[]
  topup        WalletTopup[]
}

model WalletTransaction {
  transaction_id String   @id @default(uuid())
  wallet_id      String
  amount         Int
  type           String
  balance_before Int
  balance_after  Int
  reference_id   String   @unique
  created_at     DateTime @default(now())

  wallet Wallet       @relation(fields: [wallet_id], references: [wallet_id])
  topup  WalletTopup?
  order  Order?
}

model WalletTopup {
  topup_id       String   @id @default(uuid())
  wallet_id      String
  transaction_id String?   @unique
  idempotency_key String   @unique
  amount         Int
  fee            Int
  method         String
  status         String
  created_at     DateTime @default(now())

  wallet      Wallet             @relation(fields: [wallet_id], references: [wallet_id])
  transaction WalletTransaction? @relation(fields: [transaction_id], references: [transaction_id])
}

model Product {
  product_id  String   @id @default(uuid())
  name        String
  description String?
  price       Int
  stock       Int      @default(-1) // -1 หมายถึง Unlimited Stock
  image_url   String?
  is_active   Boolean  @default(true)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  order_items OrderItem[]
}

model Order {
  order_id       String   @id @default(uuid())
  user_id        String
  transaction_id String?  @unique
  total_amount   Int
  status         String   @default("PENDING") // PENDING, COMPLETED, CANCELLED

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user        User               @relation(fields: [user_id], references: [user_id])
  transaction WalletTransaction? @relation(fields: [transaction_id], references: [transaction_id])
  items       OrderItem[]
}

model OrderItem {
  order_item_id String @id @default(uuid())
  order_id      String
  product_id    String
  quantity      Int    @default(1)
  price_at_purchase Int

  order   Order   @relation(fields: [order_id], references: [order_id])
  product Product @relation(fields: [product_id], references: [product_id])
}
